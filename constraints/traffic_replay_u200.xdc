# Xilinx Alveo U200 top-level constraints for traffic_replay_bd_wrapper.
#
# DDR4 C0 address/data pin placement is generated by the DDR4 IP through the
# U200 board interface. This file records the external clocks, PCIe, QSFP0,
# QSFP0 sideband pins, and bitstream configuration used by this design.

# General configuration, matching the Alveo U200 flash/configuration scheme.
set_property CFGBVS GND [current_design]
set_property CONFIG_VOLTAGE 1.8 [current_design]
set_property CONFIG_MODE B_SCAN [current_design]
set_property BITSTREAM.GENERAL.COMPRESS true [current_design]
set_property BITSTREAM.CONFIG.CONFIGFALLBACK ENABLE [current_design]
set_property BITSTREAM.CONFIG.EXTMASTERCCLK_EN DISABLE [current_design]
set_property BITSTREAM.CONFIG.CONFIGRATE 63.8 [current_design]
set_property BITSTREAM.CONFIG.UNUSEDPIN PULLUP [current_design]
set_property BITSTREAM.CONFIG.OVERTEMPSHUTDOWN Enable [current_design]
set_operating_conditions -design_power_budget 160

# DDR4 C0 300 MHz reference clock.
set_property LOC AY37 [get_ports -quiet default_300mhz_clk0_clk_p]
set_property IOSTANDARD LVDS [get_ports -quiet default_300mhz_clk0_clk_p]
set_property LOC AY38 [get_ports -quiet default_300mhz_clk0_clk_n]
set_property IOSTANDARD LVDS [get_ports -quiet default_300mhz_clk0_clk_n]

# PCIe x16 Gen3 MGT lanes and 100 MHz reference clock.
set_property LOC AF2 [get_ports -quiet {pci_express_x16_rxp[0]}]
set_property LOC AF1 [get_ports -quiet {pci_express_x16_rxn[0]}]
set_property LOC AF7 [get_ports -quiet {pci_express_x16_txp[0]}]
set_property LOC AF6 [get_ports -quiet {pci_express_x16_txn[0]}]
set_property LOC AG4 [get_ports -quiet {pci_express_x16_rxp[1]}]
set_property LOC AG3 [get_ports -quiet {pci_express_x16_rxn[1]}]
set_property LOC AG9 [get_ports -quiet {pci_express_x16_txp[1]}]
set_property LOC AG8 [get_ports -quiet {pci_express_x16_txn[1]}]
set_property LOC AH2 [get_ports -quiet {pci_express_x16_rxp[2]}]
set_property LOC AH1 [get_ports -quiet {pci_express_x16_rxn[2]}]
set_property LOC AH7 [get_ports -quiet {pci_express_x16_txp[2]}]
set_property LOC AH6 [get_ports -quiet {pci_express_x16_txn[2]}]
set_property LOC AJ4 [get_ports -quiet {pci_express_x16_rxp[3]}]
set_property LOC AJ3 [get_ports -quiet {pci_express_x16_rxn[3]}]
set_property LOC AJ9 [get_ports -quiet {pci_express_x16_txp[3]}]
set_property LOC AJ8 [get_ports -quiet {pci_express_x16_txn[3]}]
set_property LOC AK2 [get_ports -quiet {pci_express_x16_rxp[4]}]
set_property LOC AK1 [get_ports -quiet {pci_express_x16_rxn[4]}]
set_property LOC AK7 [get_ports -quiet {pci_express_x16_txp[4]}]
set_property LOC AK6 [get_ports -quiet {pci_express_x16_txn[4]}]
set_property LOC AL4 [get_ports -quiet {pci_express_x16_rxp[5]}]
set_property LOC AL3 [get_ports -quiet {pci_express_x16_rxn[5]}]
set_property LOC AL9 [get_ports -quiet {pci_express_x16_txp[5]}]
set_property LOC AL8 [get_ports -quiet {pci_express_x16_txn[5]}]
set_property LOC AM2 [get_ports -quiet {pci_express_x16_rxp[6]}]
set_property LOC AM1 [get_ports -quiet {pci_express_x16_rxn[6]}]
set_property LOC AM7 [get_ports -quiet {pci_express_x16_txp[6]}]
set_property LOC AM6 [get_ports -quiet {pci_express_x16_txn[6]}]
set_property LOC AN4 [get_ports -quiet {pci_express_x16_rxp[7]}]
set_property LOC AN3 [get_ports -quiet {pci_express_x16_rxn[7]}]
set_property LOC AN9 [get_ports -quiet {pci_express_x16_txp[7]}]
set_property LOC AN8 [get_ports -quiet {pci_express_x16_txn[7]}]
set_property LOC AP2 [get_ports -quiet {pci_express_x16_rxp[8]}]
set_property LOC AP1 [get_ports -quiet {pci_express_x16_rxn[8]}]
set_property LOC AP7 [get_ports -quiet {pci_express_x16_txp[8]}]
set_property LOC AP6 [get_ports -quiet {pci_express_x16_txn[8]}]
set_property LOC AR4 [get_ports -quiet {pci_express_x16_rxp[9]}]
set_property LOC AR3 [get_ports -quiet {pci_express_x16_rxn[9]}]
set_property LOC AR9 [get_ports -quiet {pci_express_x16_txp[9]}]
set_property LOC AR8 [get_ports -quiet {pci_express_x16_txn[9]}]
set_property LOC AT2 [get_ports -quiet {pci_express_x16_rxp[10]}]
set_property LOC AT1 [get_ports -quiet {pci_express_x16_rxn[10]}]
set_property LOC AT7 [get_ports -quiet {pci_express_x16_txp[10]}]
set_property LOC AT6 [get_ports -quiet {pci_express_x16_txn[10]}]
set_property LOC AU4 [get_ports -quiet {pci_express_x16_rxp[11]}]
set_property LOC AU3 [get_ports -quiet {pci_express_x16_rxn[11]}]
set_property LOC AU9 [get_ports -quiet {pci_express_x16_txp[11]}]
set_property LOC AU8 [get_ports -quiet {pci_express_x16_txn[11]}]
set_property LOC AV2 [get_ports -quiet {pci_express_x16_rxp[12]}]
set_property LOC AV1 [get_ports -quiet {pci_express_x16_rxn[12]}]
set_property LOC AV7 [get_ports -quiet {pci_express_x16_txp[12]}]
set_property LOC AV6 [get_ports -quiet {pci_express_x16_txn[12]}]
set_property LOC AW4 [get_ports -quiet {pci_express_x16_rxp[13]}]
set_property LOC AW3 [get_ports -quiet {pci_express_x16_rxn[13]}]
set_property LOC BB5 [get_ports -quiet {pci_express_x16_txp[13]}]
set_property LOC BB4 [get_ports -quiet {pci_express_x16_txn[13]}]
set_property LOC BA2 [get_ports -quiet {pci_express_x16_rxp[14]}]
set_property LOC BA1 [get_ports -quiet {pci_express_x16_rxn[14]}]
set_property LOC BD5 [get_ports -quiet {pci_express_x16_txp[14]}]
set_property LOC BD4 [get_ports -quiet {pci_express_x16_txn[14]}]
set_property LOC BC2 [get_ports -quiet {pci_express_x16_rxp[15]}]
set_property LOC BC1 [get_ports -quiet {pci_express_x16_rxn[15]}]
set_property LOC BF5 [get_ports -quiet {pci_express_x16_txp[15]}]
set_property LOC BF4 [get_ports -quiet {pci_express_x16_txn[15]}]

set_property LOC AM11 [get_ports -quiet pcie_refclk_clk_p]
set_property LOC AM10 [get_ports -quiet pcie_refclk_clk_n]

set_property LOC BD21 [get_ports -quiet pcie_perstn]
set_property IOSTANDARD LVCMOS12 [get_ports -quiet pcie_perstn]
set_property PULLUP true [get_ports -quiet pcie_perstn]
set_false_path -from [get_ports -quiet pcie_perstn]

# QSFP0 4x25G lanes and 161.1328125 MHz MGT reference clock.
set_property LOC N4 [get_ports -quiet {qsfp0_4x_grx_p[0]}]
set_property LOC N3 [get_ports -quiet {qsfp0_4x_grx_n[0]}]
set_property LOC N9 [get_ports -quiet {qsfp0_4x_gtx_p[0]}]
set_property LOC N8 [get_ports -quiet {qsfp0_4x_gtx_n[0]}]
set_property LOC M2 [get_ports -quiet {qsfp0_4x_grx_p[1]}]
set_property LOC M1 [get_ports -quiet {qsfp0_4x_grx_n[1]}]
set_property LOC M7 [get_ports -quiet {qsfp0_4x_gtx_p[1]}]
set_property LOC M6 [get_ports -quiet {qsfp0_4x_gtx_n[1]}]
set_property LOC L4 [get_ports -quiet {qsfp0_4x_grx_p[2]}]
set_property LOC L3 [get_ports -quiet {qsfp0_4x_grx_n[2]}]
set_property LOC L9 [get_ports -quiet {qsfp0_4x_gtx_p[2]}]
set_property LOC L8 [get_ports -quiet {qsfp0_4x_gtx_n[2]}]
set_property LOC K2 [get_ports -quiet {qsfp0_4x_grx_p[3]}]
set_property LOC K1 [get_ports -quiet {qsfp0_4x_grx_n[3]}]
set_property LOC K7 [get_ports -quiet {qsfp0_4x_gtx_p[3]}]
set_property LOC K6 [get_ports -quiet {qsfp0_4x_gtx_n[3]}]

set_property LOC K11 [get_ports -quiet qsfp0_161mhz_clk_p]
set_property LOC K10 [get_ports -quiet qsfp0_161mhz_clk_n]

# QSFP1 MGT lane and reference-clock constraints are in
# traffic_replay_u200_qsfp1.xdc and are added only for dual-port builds.

# DDR/UI logic and CMAC AXIS logic cross only through explicit async FIFOs.
set_clock_groups -asynchronous -group [get_clocks -regexp -quiet {^mmcm_clkout0$}] -group [get_clocks -regexp -quiet {txoutclk.*}]

# QSFP0 module and reference-clock sideband. The BD ties these to constants:
# resetl=1, lpmode=0, refclk_reset=0, fs=2'b10 for 161.1328125 MHz.
set_property LOC BE16 [get_ports -quiet qsfp0_modsell]
set_property IOSTANDARD LVCMOS12 [get_ports -quiet qsfp0_modsell]
set_property SLEW SLOW [get_ports -quiet qsfp0_modsell]
set_property DRIVE 8 [get_ports -quiet qsfp0_modsell]
set_property LOC BE17 [get_ports -quiet qsfp0_resetl]
set_property IOSTANDARD LVCMOS12 [get_ports -quiet qsfp0_resetl]
set_property SLEW SLOW [get_ports -quiet qsfp0_resetl]
set_property DRIVE 8 [get_ports -quiet qsfp0_resetl]
set_property LOC BD18 [get_ports -quiet qsfp0_lpmode]
set_property IOSTANDARD LVCMOS12 [get_ports -quiet qsfp0_lpmode]
set_property SLEW SLOW [get_ports -quiet qsfp0_lpmode]
set_property DRIVE 8 [get_ports -quiet qsfp0_lpmode]
set_property LOC AT22 [get_ports -quiet qsfp0_refclk_reset]
set_property IOSTANDARD LVCMOS12 [get_ports -quiet qsfp0_refclk_reset]
set_property SLEW SLOW [get_ports -quiet qsfp0_refclk_reset]
set_property DRIVE 8 [get_ports -quiet qsfp0_refclk_reset]
set_property LOC AT20 [get_ports -quiet {qsfp0_fs[0]}]
set_property IOSTANDARD LVCMOS12 [get_ports -quiet {qsfp0_fs[0]}]
set_property SLEW SLOW [get_ports -quiet {qsfp0_fs[0]}]
set_property DRIVE 8 [get_ports -quiet {qsfp0_fs[0]}]
set_property LOC AU22 [get_ports -quiet {qsfp0_fs[1]}]
set_property IOSTANDARD LVCMOS12 [get_ports -quiet {qsfp0_fs[1]}]
set_property SLEW SLOW [get_ports -quiet {qsfp0_fs[1]}]
set_property DRIVE 8 [get_ports -quiet {qsfp0_fs[1]}]
set_false_path -to [get_ports -quiet {qsfp0_modsell qsfp0_resetl qsfp0_lpmode qsfp0_refclk_reset qsfp0_fs[*]}]

# QSFP1 module and reference-clock sideband. The BD ties these to constants:
# resetl=1, lpmode=0, refclk_reset=0, fs=2'b10 for 161.1328125 MHz.
set_property LOC AY20 [get_ports -quiet qsfp1_modsell]
set_property IOSTANDARD LVCMOS12 [get_ports -quiet qsfp1_modsell]
set_property SLEW SLOW [get_ports -quiet qsfp1_modsell]
set_property DRIVE 8 [get_ports -quiet qsfp1_modsell]
set_property LOC BC18 [get_ports -quiet qsfp1_resetl]
set_property IOSTANDARD LVCMOS12 [get_ports -quiet qsfp1_resetl]
set_property SLEW SLOW [get_ports -quiet qsfp1_resetl]
set_property DRIVE 8 [get_ports -quiet qsfp1_resetl]
set_property LOC AV22 [get_ports -quiet qsfp1_lpmode]
set_property IOSTANDARD LVCMOS12 [get_ports -quiet qsfp1_lpmode]
set_property SLEW SLOW [get_ports -quiet qsfp1_lpmode]
set_property DRIVE 8 [get_ports -quiet qsfp1_lpmode]
set_property LOC AR21 [get_ports -quiet qsfp1_refclk_reset]
set_property IOSTANDARD LVCMOS12 [get_ports -quiet qsfp1_refclk_reset]
set_property SLEW SLOW [get_ports -quiet qsfp1_refclk_reset]
set_property DRIVE 8 [get_ports -quiet qsfp1_refclk_reset]
set_property LOC AR22 [get_ports -quiet {qsfp1_fs[0]}]
set_property IOSTANDARD LVCMOS12 [get_ports -quiet {qsfp1_fs[0]}]
set_property SLEW SLOW [get_ports -quiet {qsfp1_fs[0]}]
set_property DRIVE 8 [get_ports -quiet {qsfp1_fs[0]}]
set_property LOC AU20 [get_ports -quiet {qsfp1_fs[1]}]
set_property IOSTANDARD LVCMOS12 [get_ports -quiet {qsfp1_fs[1]}]
set_property SLEW SLOW [get_ports -quiet {qsfp1_fs[1]}]
set_property DRIVE 8 [get_ports -quiet {qsfp1_fs[1]}]
set_false_path -to [get_ports -quiet {qsfp1_modsell qsfp1_resetl qsfp1_lpmode qsfp1_refclk_reset qsfp1_fs[*]}]
